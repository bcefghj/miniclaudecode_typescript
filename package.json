{
  "name": "miniclaudecode_typescript",
  "version": "1.0.0",
  "description": "Claude Code distilled into 12 progressive TypeScript stages — from a while loop to multi-agent teams",
  "type": "module",
  "main": "dist/s12_worktree.js",
  "bin": {
    "minicc": "dist/s12_worktree.js"
  },
  "scripts": {
    "build": "tsc",
    "s01": "npx tsx src/s01_agent_loop.ts",
    "s02": "npx tsx src/s02_tools.ts",
    "s03": "npx tsx src/s03_todo.ts",
    "s04": "npx tsx src/s04_subagent.ts",
    "s05": "npx tsx src/s05_skills.ts",
    "s06": "npx tsx src/s06_compact.ts",
    "s07": "npx tsx src/s07_tasks.ts",
    "s08": "npx tsx src/s08_background.ts",
    "s09": "npx tsx src/s09_teams.ts",
    "s10": "npx tsx src/s10_protocols.ts",
    "s11": "npx tsx src/s11_autonomous.ts",
    "s12": "npx tsx src/s12_worktree.ts"
  },
  "keywords": ["claude-code", "agent", "distillation", "typescript", "ai"],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "chalk": "^5.4.1"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsx": "^4.19.0",
    "@types/node": "^22.0.0"
  }
}
